{
  "name": "virallinkup-studio",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon --esm server/index.js",
    "client": "vite",
    "build": "vite build && esbuild server/index.js --bundle --platform=node --format=esm --packages=external --outfile=dist/server.mjs",
    "start": "node dist/server.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "axios": "^1.7.2",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-ws": "^5.0.2",
    "fs-extra": "^11.2.0",
    "node-pty": "^1.0.0",
    "octokit": "^4.0.2",
    "simple-git": "^3.25.0",
    "ws": "^8.18.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "esbuild": "^0.21.5",
    "nodemon": "^3.1.4",
    "vite": "^5.3.1"
  }
}
