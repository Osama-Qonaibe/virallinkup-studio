{
  "name": "virallinkup-studio",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon --esm server/index.js",
    "client": "vite",
    "build": "vite build && esbuild server/index.js --bundle --platform=node --format=esm --packages=external --outfile=dist/server.mjs",
    "start": "node dist/server.mjs"
  },
  "dependencies": {
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "@monaco-editor/react": "^4.6.0",
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "dockerode": "^4.0.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-ws": "^5.0.2",
    "fs-extra": "^11.2.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.0",
    "node-pty": "^1.0.0",
    "octokit": "^4.0.2",
    "pg": "^8.12.0",
    "simple-git": "^3.25.0",
    "ws": "^8.18.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.13",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "esbuild": "^0.21.5",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "vite": "^5.3.1"
  }
}
