# Server
PORT=4000
NODE_ENV=production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/studio

# Admin Auth (bcrypt hash of password)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=$2b$12$...
STUDIO_JWT_SECRET=change-this-to-a-long-random-string

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=your-username

# Projects
PROJECTS_DIR=/home/user/projects

# Docker (optional, defaults to /var/run/docker.sock)
DOCKER_SOCKET=/var/run/docker.sock
